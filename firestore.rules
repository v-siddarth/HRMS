rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.role == 'super_admin';
    }

    function isShopManager(shopId) {
      return signedIn() && request.auth.token.role == 'shop_manager' && request.auth.token.shopId == shopId;
    }

    function isStaff(shopId) {
      return signedIn()
        && request.auth.token.role == 'staff'
        && request.auth.token.shopId == shopId
        && request.auth.token.employeeId != null;
    }

    function isOwnEmployee(employeeId) {
      return signedIn() && request.auth.token.employeeId == employeeId;
    }

    function isShopOwnerDoc() {
      return signedIn() && resource != null && resource.data.authUid == request.auth.uid;
    }

    function isShopOwner(shopId) {
      return signedIn() && get(/databases/$(database)/documents/shops/$(shopId)).data.authUid == request.auth.uid;
    }

    match /admins/{uid} {
      allow read, write: if isAdmin();
    }

    match /shops/{shopId} {
      allow read: if isAdmin() || isShopManager(shopId) || isStaff(shopId) || isShopOwnerDoc() || isShopOwner(shopId);
      allow write: if isAdmin() || isShopManager(shopId) || isShopOwner(shopId);

      match /managers/{uid} {
        allow read, write: if isAdmin() || isShopManager(shopId) || isShopOwner(shopId);
      }

      match /employees/{employeeId} {
        allow read: if isAdmin() || isShopManager(shopId) || isShopOwner(shopId) || (isStaff(shopId) && isOwnEmployee(employeeId));
        allow write: if isAdmin() || isShopManager(shopId) || isShopOwner(shopId);
      }

      match /attendance/{attendanceId} {
        allow read: if isAdmin() || isShopManager(shopId) || isShopOwner(shopId)
          || (isStaff(shopId) && resource.data.employeeId == request.auth.token.employeeId);
        allow create, update: if isAdmin() || isShopManager(shopId) || isShopOwner(shopId)
          || (
            request.resource.data.shopId == shopId
            && (isStaff(shopId) && request.resource.data.employeeId == request.auth.token.employeeId)
          );
        allow delete: if isAdmin() || isShopManager(shopId) || isShopOwner(shopId);
      }

      match /salary/{salaryId} {
        allow read: if isAdmin() || isShopManager(shopId) || isShopOwner(shopId)
          || (isStaff(shopId) && resource.data.employeeId == request.auth.token.employeeId);
        allow write: if isAdmin() || isShopManager(shopId) || isShopOwner(shopId);
      }

      match /advances/{advanceId} {
        allow read: if isAdmin() || isShopManager(shopId) || isShopOwner(shopId)
          || (isStaff(shopId) && resource.data.employeeId == request.auth.token.employeeId);
        allow write: if isAdmin() || isShopManager(shopId) || isShopOwner(shopId);
      }

      match /shifts/{shiftId} {
        allow read: if isAdmin() || isShopManager(shopId) || isShopOwner(shopId) || isStaff(shopId);
        allow write: if isAdmin() || isShopManager(shopId) || isShopOwner(shopId);
      }

      match /weekly_shift_plans/{planId} {
        allow read: if isAdmin() || isShopManager(shopId) || isShopOwner(shopId)
          || (isStaff(shopId) && resource.data.employeeId == request.auth.token.employeeId);
        allow write: if isAdmin() || isShopManager(shopId) || isShopOwner(shopId);
      }

      match /staff_weekly_shifts/{planId} {
        allow read: if isAdmin() || isShopManager(shopId) || isShopOwner(shopId)
          || (isStaff(shopId) && resource.data.staff_id == request.auth.token.employeeId);
        allow write: if isAdmin() || isShopManager(shopId) || isShopOwner(shopId);
      }

      match /settings/{settingId} {
        allow read: if isAdmin() || isShopManager(shopId) || isShopOwner(shopId) || isStaff(shopId);
        allow write: if isAdmin() || isShopManager(shopId) || isShopOwner(shopId);
      }
    }
  }
}
